#!/usr/bin/env ruby
# frozen_string_literal: true
#
# This file was generated by Bundler.
#
# The application's bundle is created when `bundle install` is run.
# The executable version of bundler that is invoked is determined by the
# $BUNDLE_BIN_PATH or $BUNDLE_GEMFILE environment variables. This file will
# always be the bundler that is in your bundle's gemspec.

require "rubygems"

m = Module.new do
  module_function

  def invoked_as_script?
    File.expand_path($0) == File.expand_path(__FILE__)
  end

  def env_var_version
    ENV["BUNDLER_VERSION"]
  end

  def cli_arg_version
    return unless invoked_as_script?
    bundler_version = nil
    update_index = nil
    ARGV.each_with_index do |a, i|
      bundler_version = a if update_index && update_index.succ == i
      next unless a =~ /\A--bundler\z/
      update_index = i
    end
    bundler_version
  end

  def gemfile
    gemfile = ENV["BUNDLE_GEMFILE"]
    return gemfile if gemfile && !gemfile.empty?
    File.expand_path("../Gemfile", __dir__)
  end

  def lockfile
    lockfile = gemfile + ".lock"
    return lockfile if File.file?(lockfile)
  end

  def lockfile_version
    return unless (lf = lockfile)
    lockfile_contents = File.read(lf)
    return unless lockfile_contents =~ /\A.*^BUNDLED WITH$\s*(#{Gem::Version::VERSION_PATTERN})\s*$/m
    Regexp.last_match(1)
  end

  def current_version
    Gem::Version.new(Bundler::VERSION)
  end

  def requirement
    @requirement ||= Gem::Requirement.new(bundler_version)
  end

  def bundler_version
    @bundler_version ||= env_var_version || cli_arg_version || lockfile_version
  end

  def load_bundler!
    $LOAD_PATH.unshift(File.join(Gem.default_dir, "gems", "bundler-#{current_version}", "lib"))
    require "bundler"
    unless requirement.satisfied_by?(current_version)
      abort "Bundler version #{current_version} is not compatible with lockfile. Use version #{requirement} instead."
    end
  end

  def invoke_bundler!
    if Gem.respond_to?(:activate_bin_path)
      load Gem.activate_bin_path("bundler", "bundle", bundler_version)
    else
      gem "bundler", requirement
      load Gem.bin_path("bundler", "bundle")
    end
  end
end

m.load_bundler!
m.invoke_bundler!
