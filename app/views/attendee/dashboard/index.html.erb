<div class="flex items-center justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">My events</h1>
    <p class="text-gray-500 text-sm">Your registrations and tickets.</p>
  </div>
  <%= link_to attendee_discover_path, class: "btn-primary" do %>
    Discover events
  <% end %>
</div>

<% if @registrations.empty? %>
  <div class="card py-20 text-center">
    <svg class="w-12 h-12 mx-auto text-gray-200 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
    <p class="text-gray-500 mb-4">No tickets yet. Find an event and register to get started.</p>
    <%= link_to "Browse events", attendee_discover_path, class: "btn-primary" %>
  </div>
<% else %>
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <% @registrations.each do |reg| %>
      <div class="ticket-badge">
        <div class="ticket-body">
          <div class="text-xs text-gray-400 font-medium uppercase tracking-wide"><%= reg.ticket_tier.name %></div>
          <%= link_to reg.event.name, public_event_path(reg.event.slug), class: "font-bold text-gray-900 text-lg leading-tight hover:text-emerald-600 mt-0.5 block" %>
          <div class="text-sm text-gray-500"><%= reg.event.date_range %></div>
          <div class="text-sm text-gray-500"><%= reg.event.location %></div>
          <div class="flex items-center gap-3 mt-3 pt-3 border-t border-gray-100">
            <span class="ticket-code"><%= reg.code %></span>
            <% if reg.checked_in? %>
              <span class="badge-green">Checked in</span>
            <% else %>
              <span class="badge-amber">Not scanned yet</span>
            <% end %>
          </div>
        </div>
        <div class="ticket-qr">
          <!-- QR placeholder (real QR needs rqrcode gem) -->
          <div class="w-20 h-20 bg-gray-900 rounded p-1.5 grid grid-cols-5 gap-0.5">
            <% 25.times do |i| %>
              <div class="<%= [true,false,true,false,true,false,false,true,false,true,true,true,false,true,false,false,true,false,true,false,true,false,true,false,true][i % 25] ? 'bg-white' : 'bg-gray-900' %> rounded-sm"></div>
            <% end %>
          </div>
          <span class="text-xs text-gray-400 text-center">Scan at door</span>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
