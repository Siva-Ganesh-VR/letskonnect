<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Networking</h1>
  <p class="text-gray-500 text-sm">People at your events, ranked by shared interests.</p>
</div>

<% if @registered_events.empty? %>
  <div class="card p-12 text-center">
    <p class="text-gray-500">Register for an event to see who else is attending.</p>
    <%= link_to "Discover events", attendee_discover_path, class: "btn-primary mt-3 inline-block" %>
  </div>
<% else %>
  <!-- Event selector -->
  <div class="flex gap-2 mb-5">
    <% @registered_events.each do |ev| %>
      <%= link_to ev.name, attendee_networking_path(event_id: ev.id),
          class: "px-3 py-1.5 rounded-lg text-sm font-medium transition-colors #{@event&.id == ev.id ? 'bg-emerald-600 text-white' : 'bg-white border border-gray-200 text-gray-600 hover:border-gray-300'}" %>
    <% end %>
  </div>

  <% if @event %>
    <!-- Incoming requests -->
    <% incoming = @connections.select { |c| c.to_user_id == current_user.id && c.status == "pending" } %>
    <% if incoming.any? %>
      <div class="card border-emerald-200 bg-emerald-50 p-4 mb-4">
        <div class="font-semibold text-emerald-800 mb-2">Connection requests</div>
        <% incoming.each do |c| %>
          <div class="flex items-center justify-between py-2">
            <span class="text-sm font-medium"><%= User.find_by(id: c.from_user_id)&.name %> wants to connect</span>
            <div class="flex gap-2">
              <%= button_to "Accept", attendee_connection_path(c), params: { status: "accepted" }, method: :patch, class: "btn-green text-xs px-3 py-1" %>
              <%= button_to "Decline", attendee_connection_path(c), params: { status: "declined" }, method: :patch, class: "btn-outline text-xs px-3 py-1" %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- People grid -->
    <div class="grid grid-cols-2 gap-3">
      <% @scored.each do |item| %>
        <% p = item[:user]; score = item[:match] %>
        <% conn = @connections.find { |c| (c.from_user_id == current_user.id && c.to_user_id == p.id) || (c.to_user_id == current_user.id && c.from_user_id == p.id) } %>
        <div class="card p-4 flex flex-col gap-2">
          <div class="flex items-start justify-between gap-2">
            <div class="flex items-center gap-2">
              <div class="avatar-lg"><%= p.initials %></div>
              <div>
                <div class="font-medium text-gray-900"><%= p.name %></div>
                <div class="text-xs text-gray-400"><%= p.title %><%= p.company.present? ? " · #{p.company}" : "" %></div>
              </div>
            </div>
            <% if score > 0 %>
              <span class="badge-green flex-shrink-0"><%= score %> shared</span>
            <% end %>
          </div>
          <% if p.interests.present? %>
            <div class="text-xs text-gray-400">Into: <%= p.interests %></div>
          <% end %>
          <div class="mt-auto pt-2">
            <% if conn.nil? %>
              <%= button_to "Request to connect", attendee_connections_path(event_id: @event.id, to_user_id: p.id),
                  method: :post, class: "btn-outline text-xs w-full" %>
            <% elsif conn.status == "pending" %>
              <span class="badge-amber">Request pending</span>
            <% elsif conn.status == "accepted" %>
              <span class="badge-green">Connected ✓</span>
            <% end %>
          </div>
        </div>
      <% end %>
      <% if @scored.empty? %>
        <div class="col-span-2 text-center py-10 text-gray-400">No other attendees yet — you're early!</div>
      <% end %>
    </div>
  <% end %>
<% end %>
