<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Discover events</h1>
  <p class="text-gray-500 text-sm">Live on LetsKonnect right now.</p>
</div>
<div class="grid grid-cols-3 gap-4">
  <% @events.each do |ev| %>
    <%= link_to public_event_path(ev.slug), class: "card overflow-hidden hover:shadow-md transition-shadow group" do %>
      <% if ev.hero_image.present? %>
        <img src="<%= ev.hero_image %>" alt="" class="h-36 w-full object-cover">
      <% end %>
      <div class="p-4 space-y-1">
        <div class="flex items-center gap-1.5">
          <span class="badge-gray text-xs"><%= ev.event_type %></span>
          <% if ev.live? %><span class="badge-green flex items-center gap-1"><span class="live-dot w-1.5 h-1.5"></span>Live</span><% end %>
        </div>
        <div class="font-bold text-gray-900 group-hover:text-emerald-600"><%= ev.name %></div>
        <div class="text-sm text-gray-500"><%= ev.date_range %></div>
        <div class="text-sm text-gray-400"><%= ev.location %></div>
      </div>
    <% end %>
  <% end %>
  <% if @events.empty? %>
    <div class="col-span-3 text-center py-16 text-gray-400">No published events yet.</div>
  <% end %>
</div>
