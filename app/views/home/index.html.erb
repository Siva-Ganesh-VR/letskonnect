<!DOCTYPE html>
<html lang="en"><head>
  <meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1">
  <title>LetsKonnect — The OS for modern events</title>
  <%= stylesheet_link_tag "application" %>
</head>
<body class="bg-white">
  <header class="border-b border-gray-100 px-8 py-4 flex justify-between items-center">
    <span class="logo-text text-xl"><span class="logo-lets">Lets</span><span class="logo-konnect">Konnect</span></span>
    <div class="flex gap-3">
      <%= link_to public_events_path, class: "btn-outline text-sm" do %>Discover events<% end %>
      <%= link_to login_path, class: "btn-primary text-sm" do %>Sign in<% end %>
    </div>
  </header>
  <section class="max-w-4xl mx-auto text-center py-24 px-6">
    <h1 class="text-5xl font-extrabold text-gray-900 leading-tight">The event platform built for <span class="text-emerald-600">serious organizers.</span></h1>
    <p class="mt-5 text-xl text-gray-500 max-w-2xl mx-auto">Registration, check-in, networking and analytics — from the first save-the-date to the last QR scan.</p>
    <div class="mt-8 flex gap-3 justify-center">
      <%= link_to signup_path, class: "btn-green text-base px-6 py-3" do %>Start free<% end %>
      <%= link_to login_path, class: "btn-outline text-base px-6 py-3" do %>Demo login<% end %>
    </div>
    <p class="mt-3 text-sm text-gray-400">No credit card · demo accounts pre-loaded</p>
  </section>
</body></html>
