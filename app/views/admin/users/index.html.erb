<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold">Users</h1>
  <span class="badge-gray"><%= @users.count rescue "—" %> total</span>
</div>
<div class="table-wrapper">
  <table class="data-table">
    <thead><tr><th>Name</th><th>Email</th><th>Role</th><th>Company</th><th>Joined</th><th></th></tr></thead>
    <tbody>
      <% @users.each do |u| %>
        <tr>
          <td>
            <div class="flex items-center gap-2">
              <div class="avatar"><%= u.initials %></div>
              <span class="font-medium"><%= u.name %></span>
            </div>
          </td>
          <td class="text-gray-500 text-sm"><%= u.email %></td>
          <td><span class="<%= u.role == 'admin' ? 'badge-blue' : u.role == 'organizer' ? 'badge-green' : 'badge-gray' %>"><%= u.role.capitalize %></span></td>
          <td class="text-gray-400 text-sm"><%= u.company %></td>
          <td class="text-gray-400 text-xs"><%= u.created_at.strftime("%b %-d, %Y") %></td>
          <td><%= link_to "View", admin_user_path(u), class: "text-emerald-600 text-sm hover:underline" %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
