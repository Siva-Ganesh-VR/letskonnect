<div class="mb-6 flex items-center justify-between">
  <h1 class="text-2xl font-bold">Tenants</h1>
</div>
<div class="table-wrapper">
  <table class="data-table">
    <thead><tr><th>Name</th><th>Plan</th><th>Status</th><th>MRR</th><th>Joined</th></tr></thead>
    <tbody>
      <% @tenants.each do |t| %>
        <tr>
          <td><%= link_to t.name, admin_tenant_path(t), class: "font-medium text-emerald-600 hover:underline" %></td>
          <td><span class="badge-gray"><%= t.plan.capitalize %></span></td>
          <td><span class="<%= t.status == 'active' ? 'badge-green' : 'badge-red' %>"><%= t.status.capitalize %></span></td>
          <td class="font-semibold"><%= t.monthly_display %></td>
          <td class="text-gray-400"><%= t.joined_on&.strftime("%b %-d, %Y") %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
