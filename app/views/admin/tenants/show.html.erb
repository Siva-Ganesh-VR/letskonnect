<div class="mb-6 flex justify-between items-start">
  <div>
    <h1 class="text-2xl font-bold"><%= @tenant.name %></h1>
    <div class="flex items-center gap-2 mt-1">
      <span class="badge-gray"><%= @tenant.plan.capitalize %></span>
      <span class="<%= @tenant.status == 'active' ? 'badge-green' : 'badge-red' %>"><%= @tenant.status.capitalize %></span>
      <span class="text-sm text-gray-500">Joined <%= @tenant.joined_on&.strftime("%B %-d, %Y") %></span>
    </div>
  </div>
  <div class="text-right">
    <div class="text-2xl font-bold text-gray-900"><%= @tenant.monthly_display %></div>
    <div class="text-sm text-gray-400">monthly</div>
  </div>
</div>
<div class="card">
  <div class="px-5 py-3 border-b border-gray-100 font-semibold">Support tickets</div>
  <% @tickets.each do |t| %>
    <div class="px-5 py-3 border-b border-gray-50 last:border-0 flex justify-between items-center">
      <span class="font-medium text-sm"><%= t.subject %></span>
      <span class="<%= t.priority == 'urgent' ? 'badge-red' : t.priority == 'high' ? 'badge-amber' : 'badge-gray' %>"><%= t.priority.upcase %></span>
    </div>
  <% end %>
  <% if @tickets.empty? %><div class="px-5 py-6 text-center text-gray-400 text-sm">No support tickets.</div><% end %>
</div>
