<div class="max-w-lg">
  <h1 class="text-2xl font-bold mb-6">Edit Tenant: <%= @tenant.name %></h1>
  <%= form_with model: [:admin, @tenant], local: true, class: "card p-6 space-y-4" do |f| %>
    <div class="field"><label class="label">Name</label><%= f.text_field :name, class: "input" %></div>
    <div class="field"><label class="label">Plan</label><%= f.select :plan, Tenant::PLANS.map{|p|[p.capitalize,p]}, {}, class: "input" %></div>
    <div class="field"><label class="label">Status</label><%= f.select :status, [["Active","active"],["Suspended","suspended"],["Churned","churned"]], {}, class: "input" %></div>
    <div class="field"><label class="label">Monthly (cents)</label><%= f.number_field :monthly_cents, class: "input", min: 0 %></div>
    <div class="field"><label class="label">Billing email</label><%= f.email_field :billing_email, class: "input" %></div>
    <div class="flex gap-3">
      <%= f.submit "Save", class: "btn-primary" %>
      <%= link_to "Cancel", admin_tenant_path(@tenant), class: "btn-outline" %>
    </div>
  <% end %>
</div>
