<div class="mb-6"><h1 class="text-2xl font-bold">All Events</h1></div>
<div class="table-wrapper">
  <table class="data-table">
    <thead><tr><th>Event</th><th>Organizer</th><th>Status</th><th>Registrations</th><th>Revenue</th></tr></thead>
    <tbody>
      <% @events.each do |ev| %>
        <tr>
          <td>
            <div class="font-medium text-gray-900"><%= ev.name %></div>
            <div class="text-xs text-gray-400"><%= ev.date_range %> · <%= ev.location %></div>
          </td>
          <td class="text-sm text-gray-500"><%= ev.organizer.name %></td>
          <td><span class="<%= ev.published? ? 'badge-green' : ev.status == 'draft' ? 'badge-gray' : 'badge-amber' %>"><%= ev.status.capitalize %></span></td>
          <td><%= ev.registration_count %></td>
          <td class="font-semibold">$<%= number_with_delimiter(ev.revenue_cents / 100) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
