<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <title>LetsKonnect — Admin</title>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body>
<div class="sidebar-layout">

  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="px-5 py-4 border-b border-gray-100">
      <a href="<%= admin_root_path %>" class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-emerald-600 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 3a1 1 0 110 2 1 1 0 010-2zm-1 4h2v5H9V9z"/>
          </svg>
        </div>
        <span class="logo-text"><span class="logo-lets">Lets</span><span class="logo-konnect">Konnect</span></span>
      </a>
    </div>

    <div class="sidebar-section-label">SUPER ADMIN</div>

    <nav class="flex-1 py-1 space-y-0.5">
      <a href="<%= admin_root_path %>" class="nav-item <%= 'active' if controller_name == 'dashboard' %>">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"/></svg>
        Platform overview
      </a>
      <a href="<%= admin_tenants_path %>" class="nav-item <%= 'active' if controller_name == 'tenants' %>">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/></svg>
        Tenants
      </a>
      <a href="<%= admin_subscriptions_path %>" class="nav-item <%= 'active' if controller_name == 'subscriptions' %>">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>
        Subscriptions
      </a>
      <a href="<%= admin_support_tickets_path %>" class="nav-item <%= 'active' if controller_name == 'support_tickets' %>">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
        Support tickets
      </a>
    </nav>

    <div class="border-t border-gray-100 p-4">
      <%= button_to "Sign out", logout_path, method: :delete, class: "flex items-center gap-2 text-sm text-gray-500 hover:text-gray-800 w-full" %>
    </div>
  </aside>

  <!-- Main content -->
  <div class="sidebar-content">
    <!-- Topbar -->
    <header class="topbar">
      <div></div>
      <div class="flex items-center gap-3">
        <span class="badge-green px-3 py-1 text-xs font-medium flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
          Platform
        </span>
        <div class="flex items-center gap-2">
          <div class="avatar-lg"><%= current_user.initials %></div>
          <div class="text-right">
            <div class="text-sm font-medium text-gray-700"><%= current_user.name %></div>
            <div class="text-xs text-gray-400"><%= current_user.email %></div>
          </div>
        </div>
      </div>
    </header>

    <!-- Flash -->
    <% if notice %>
      <div class="mx-6 mt-4"><div class="flash-notice"><%= notice %></div></div>
    <% end %>
    <% if alert %>
      <div class="mx-6 mt-4"><div class="flash-alert"><%= alert %></div></div>
    <% end %>

    <main class="flex-1 p-6">
      <%= yield %>
    </main>
  </div>
</div>
</body>
</html>
