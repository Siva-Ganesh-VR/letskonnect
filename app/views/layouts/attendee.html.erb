<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="csrf-token" content="<%= form_authenticity_token %>">
  <title>LetsKonnect — My Events</title>
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body>
<div class="sidebar-layout">

  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="px-5 py-4 border-b border-gray-100">
      <a href="<%= attendee_root_path %>" class="flex items-center gap-2">
        <div class="w-8 h-8 rounded-lg bg-emerald-600 flex items-center justify-center">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path d="M10 2a8 8 0 100 16A8 8 0 0010 2zm0 3a1 1 0 110 2 1 1 0 010-2zm-1 4h2v5H9V9z"/>
          </svg>
        </div>
        <span class="logo-text"><span class="logo-lets">Lets</span><span class="logo-konnect">Konnect</span></span>
      </a>
    </div>

    <div class="sidebar-section-label">ATTENDEE</div>

    <nav class="flex-1 py-1 space-y-0.5">
      <a href="<%= attendee_root_path %>" class="nav-item <%= 'active' if controller_name == 'dashboard' %>">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"/></svg>
        My events
      </a>
      <a href="<%= attendee_discover_path %>" class="nav-item <%= 'active' if controller_name == 'discover' %>">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
        Discover
      </a>
      <a href="<%= attendee_networking_path %>" class="nav-item <%= 'active' if controller_name == 'networking' %>">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        Networking
      </a>
      <a href="#" class="nav-item">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        AI assistant
        <span class="soon-badge ml-auto">SOON</span>
      </a>
      <a href="#" class="nav-item">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
        Messages
        <span class="soon-badge ml-auto">SOON</span>
      </a>
    </nav>

    <div class="border-t border-gray-100 p-4">
      <%= button_to logout_path, method: :delete, class: "flex items-center gap-2 text-sm text-gray-500 hover:text-gray-800 w-full" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
        Sign out
      <% end %>
    </div>
  </aside>

  <!-- Main content -->
  <div class="sidebar-content">
    <!-- Topbar -->
    <header class="topbar">
      <div></div>
      <div class="flex items-center gap-3">
        <div class="flex items-center gap-2">
          <div class="avatar-lg"><%= current_user.initials %></div>
          <span class="text-sm font-medium text-gray-700"><%= current_user.name %></span>
        </div>
      </div>
    </header>

    <!-- Flash -->
    <% if notice %>
      <div class="mx-6 mt-4"><div class="flash-notice"><%= notice %></div></div>
    <% end %>
    <% if alert %>
      <div class="mx-6 mt-4"><div class="flash-alert"><%= alert %></div></div>
    <% end %>

    <main class="flex-1 p-6">
      <%= yield %>
    </main>
  </div>
</div>
</body>
</html>
