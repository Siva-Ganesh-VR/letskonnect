<div class="flex items-start justify-between mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Welcome back, organizer 👋</h1>
    <p class="text-gray-500 text-sm mt-0.5">Here's what's happening across your events today.</p>
  </div>
  <%= link_to new_organizer_event_path, class: "btn-primary flex items-center gap-2" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/></svg>
    Create event
  <% end %>
</div>

<!-- Stat cards -->
<div class="grid grid-cols-4 gap-4 mb-6">
  <div class="stat-card">
    <div class="stat-label">Total registrations
      <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
    </div>
    <div class="stat-value"><%= number_with_delimiter(@total_registrations) %></div>
    <div class="stat-sub">across <%= @events.count %> events</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Checked in
      <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
    </div>
    <div class="stat-value"><%= number_with_delimiter(@total_checked_in) %></div>
    <div class="stat-sub">
      <% if @total_registrations > 0 %>
        <%= ((@total_checked_in.to_f / @total_registrations) * 100).round %>% attendance
      <% end %>
    </div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Revenue
      <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
    </div>
    <div class="stat-value">$<%= number_with_delimiter(@total_revenue_cents / 100) %></div>
    <div class="stat-sub">gross ticket revenue</div>
  </div>
  <div class="stat-card">
    <div class="stat-label">Live & upcoming
      <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
    </div>
    <div class="stat-value"><%= @live_count %></div>
    <div class="stat-sub"><%= @events.count %> total</div>
  </div>
</div>

<div class="grid grid-cols-3 gap-5">
  <!-- Recent events -->
  <div class="col-span-2 card">
    <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
      <h2 class="font-semibold text-gray-900">Recent events</h2>
      <%= link_to "View all →", organizer_events_path, class: "text-sm text-emerald-600 hover:underline" %>
    </div>
    <div>
      <% @events.first(5).each do |ev| %>
        <%= link_to organizer_event_path(ev), class: "event-row group" do %>
          <% if ev.hero_image.present? %>
            <img src="<%= ev.hero_image %>" alt="" class="event-thumb">
          <% else %>
            <div class="event-thumb flex items-center justify-center text-gray-300">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
          <% end %>
          <div class="flex-1 min-w-0">
            <div class="font-medium text-gray-900 truncate"><%= ev.name %></div>
            <div class="text-xs text-gray-400 mt-0.5"><%= ev.date_range %> · <%= ev.location %></div>
          </div>
          <div class="flex items-center gap-3 flex-shrink-0">
            <% if ev.live? %>
              <span class="badge-green flex items-center gap-1.5"><span class="live-dot"></span>Live</span>
            <% elsif ev.status == "published" %>
              <span class="badge-green">Published</span>
            <% elsif ev.status == "draft" %>
              <span class="badge-gray">Draft</span>
            <% else %>
              <span class="badge-amber">Archived</span>
            <% end %>
            <div class="text-right">
              <div class="text-sm font-semibold text-gray-900">
                <%= number_with_delimiter(ev.registration_count) %>/<%= number_with_delimiter(ev.capacity > 0 ? ev.capacity : "∞") %>
              </div>
              <div class="text-xs text-gray-400">registered</div>
            </div>
          </div>
        <% end %>
      <% end %>
      <% if @events.empty? %>
        <div class="py-12 text-center text-gray-400">
          <svg class="w-10 h-10 mx-auto mb-3 text-gray-200" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          <p class="text-sm">No events yet.</p>
          <%= link_to "Create your first event →", new_organizer_event_path, class: "text-sm text-emerald-600 hover:underline mt-1 block" %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Quick actions + tip -->
  <div class="space-y-4">
    <div class="card">
      <div class="px-4 py-3 border-b border-gray-100 font-semibold text-gray-900">Quick actions</div>
      <%= link_to new_organizer_event_path, class: "quick-action" do %>
        Create new event
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      <% end %>
      <% if @events.first %>
        <%= link_to organizer_event_checkin_index_path(@events.first), class: "quick-action" do %>
          Open check-in console
          <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        <% end %>
      <% end %>
      <%= link_to organizer_registrations_path, class: "quick-action" do %>
        Export registrations
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      <% end %>
      <%= link_to public_events_path, class: "quick-action" do %>
        Preview attendee app
        <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
      <% end %>
    </div>

    <div class="tip-box">
      <div class="font-semibold text-amber-700 mb-1">💡 Tip</div>
      <p class="text-amber-800 text-sm">Turn on AI networking for your next event to lift attendee retention by ~30%.</p>
    </div>
  </div>
</div>
