<div class="max-w-2xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Create event</h1>
    <p class="text-gray-500 text-sm mt-0.5">Starts as a draft. Publish when your microsite is ready.</p>
  </div>

  <%= form_with model: [:organizer, @event], local: true, class: "space-y-5" do |f| %>
    <% if @event.errors.any? %>
      <div class="flash-alert"><%= @event.errors.full_messages.first %></div>
    <% end %>

    <div class="card p-5 space-y-4">
      <div class="field">
        <label class="label">Event name *</label>
        <%= f.text_field :name, class: "input", placeholder: "FutureStack 2027", required: true %>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="field">
          <label class="label">Event type</label>
          <%= f.select :event_type, ["Conference", "Summit", "Exhibition", "Meetup", "Workshop"], {}, class: "input" %>
        </div>
        <div class="field">
          <label class="label">Location</label>
          <%= f.text_field :location, class: "input", placeholder: "Moscone West, San Francisco" %>
        </div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="field">
          <label class="label">Start date *</label>
          <%= f.date_field :start_date, class: "input", required: true %>
        </div>
        <div class="field">
          <label class="label">End date</label>
          <%= f.date_field :end_date, class: "input" %>
        </div>
      </div>
      <div class="field">
        <label class="label">Tagline</label>
        <%= f.text_field :tagline, class: "input", placeholder: "One punchy sentence that sells the event" %>
      </div>
      <div class="field">
        <label class="label">Description</label>
        <%= f.text_area :description, rows: 4, class: "input" %>
      </div>
      <div class="field">
        <label class="label">Capacity</label>
        <%= f.number_field :capacity, class: "input", min: 0, placeholder: "0 = unlimited" %>
      </div>
      <div class="field">
        <label class="label">Hero image URL</label>
        <%= f.url_field :hero_image, class: "input", placeholder: "https://images.unsplash.com/…" %>
      </div>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Create event", class: "btn-primary" %>
      <%= link_to "Cancel", organizer_events_path, class: "btn-outline" %>
    </div>
  <% end %>
</div>
