<div class="max-w-2xl">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Edit event</h1>
  <%= form_with model: [:organizer, @event], local: true, class: "space-y-5" do |f| %>
    <% if @event.errors.any? %>
      <div class="flash-alert"><%= @event.errors.full_messages.first %></div>
    <% end %>
    <div class="card p-5 space-y-4">
      <div class="field"><label class="label">Event name *</label><%= f.text_field :name, class: "input", required: true %></div>
      <div class="grid grid-cols-2 gap-4">
        <div class="field"><label class="label">Type</label><%= f.select :event_type, ["Conference","Summit","Exhibition","Meetup","Workshop"], {}, class: "input" %></div>
        <div class="field"><label class="label">Location</label><%= f.text_field :location, class: "input" %></div>
      </div>
      <div class="grid grid-cols-2 gap-4">
        <div class="field"><label class="label">Start date</label><%= f.date_field :start_date, class: "input" %></div>
        <div class="field"><label class="label">End date</label><%= f.date_field :end_date, class: "input" %></div>
      </div>
      <div class="field"><label class="label">Tagline</label><%= f.text_field :tagline, class: "input" %></div>
      <div class="field"><label class="label">Description</label><%= f.text_area :description, rows: 4, class: "input" %></div>
      <div class="field"><label class="label">Capacity</label><%= f.number_field :capacity, class: "input", min: 0 %></div>
      <div class="field"><label class="label">Hero image URL</label><%= f.url_field :hero_image, class: "input" %></div>
      <div class="field">
        <label class="label">Status</label>
        <%= f.select :status, [["Draft","draft"],["Published","published"],["Archived","archived"]], {}, class: "input" %>
      </div>
    </div>
    <div class="flex gap-3">
      <%= f.submit "Save changes", class: "btn-primary" %>
      <%= link_to "Cancel", organizer_event_path(@event), class: "btn-outline" %>
      <%= button_to "Delete event", organizer_event_path(@event), method: :delete,
          data: { confirm: "This will delete the event and all registrations. Are you sure?" }, class: "btn-danger ml-auto" %>
    </div>
  <% end %>
</div>
